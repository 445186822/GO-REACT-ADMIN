APP_NAME=Enterprise Demo
APP_ENV=development
HTTP_ADDR=:8080
ALLOWED_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
INITIAL_ADMIN_PASSWORD=
DATABASE_URL=postgres://enterprise:enterprise@localhost:5432/enterprise_demo?sslmode=disable
REDIS_ADDR=localhost:6379
UPLOAD_DIR=uploads
KAFKA_BROKERS=localhost:9092
RABBITMQ_URL=amqp://admin:admin123@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
RABBITMQ_MANAGEMENT_USER=admin
RABBITMQ_MANAGEMENT_PASS=admin123

# Runtime responsibilities. Disable these on secondary API instances or when migrations/seed are run by CI/CD jobs.
AUTO_MIGRATE=true
AUTO_SEED=true
SCHEDULER_ENABLED=true

# Non-streaming assistant endpoint used by /ai-assistant/chat.
AI_ASSISTANT_ENDPOINT=
AI_ASSISTANT_API_KEY=

# Streaming assistant endpoint used by /ai/chat.
AI_STREAM_BASE_URL=https://api.deepseek.com/anthropic
AI_STREAM_MODEL=deepseek-v4-flash
AI_STREAM_API_KEY=

# Legacy fallback for AI_STREAM_API_KEY.
AI_API_KEY=
